---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---
<BaseLayout title="Notes — Marco Biroli">
  <section class="no-rule" style="padding-top: 50px;">
    <div class="hd">
      <div class="label">— Notes</div>
      <h2><em>Research</em> explainers and miscellany.</h2>
    </div>
    <div class="note-list">
      {notes.map((n) => (
        <article>
          <div class="date">{n.data.date.toISOString().slice(0, 10)}</div>
          <div>
            <h3><a href={`/notes/${n.id}`}>{n.data.title}</a></h3>
            <p>{n.data.summary}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
