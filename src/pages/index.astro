---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Plate from '../components/Plate.astro';
import ResearchThreads from '../components/ResearchThreads.astro';
import Currently from '../components/Currently.astro';
import News from '../components/News.astro';
import PaperEntry from '../components/PaperEntry.astro';
import { getCollection } from 'astro:content';
import { scholarInfoFor, scholarStats } from '../lib/scholar';

const papers = (await getCollection('papers')).sort(
  (a, b) => b.data.year - a.data.year,
);
const scholarMap = scholarInfoFor(papers);
const stats = scholarStats();

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Marco Biroli',
  givenName: 'Marco',
  familyName: 'Biroli',
  jobTitle: 'Research Scholar',
  affiliation: {
    '@type': 'CollegeOrUniversity',
    name: 'University of Chicago',
    url: 'https://www.uchicago.edu',
  },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'LPTMS, Université Paris-Saclay' },
    { '@type': 'CollegeOrUniversity', name: 'École Normale Supérieure' },
    { '@type': 'CollegeOrUniversity', name: 'École Polytechnique' },
  ],
  sameAs: [
    'https://scholar.google.com/citations?user=U4DVTL0AAAAJ',
    'https://github.com/marcobiroli',
  ],
  url: 'https://marcobiroli.github.io',
  email: 'mailto:marco.biroli@gmail.com',
  knowsAbout: [
    'Statistical physics',
    'Extreme value statistics',
    'Stochastic resetting',
    'Random matrix theory',
    'Order statistics',
    'Correlated particle systems',
    'Machine learning',
  ],
};
---
<BaseLayout
  title="Marco Biroli"
  jsonLd={personJsonLd}
  ogType="profile"
  keywords={[
    'statistical physics',
    'extreme value statistics',
    'stochastic resetting',
    'random matrix theory',
    'machine learning',
    'Marco Biroli',
  ]}
>
  <Hero />
  <Plate />
  <ResearchThreads />
  <Currently />
  <News />

  <section id="papers" class="pubs">
    <div class="hd">
      <h2>Publications</h2>
    </div>
    {stats && (
      <p class="scholar-line">
        {stats.total.toLocaleString('en-US')} citations &nbsp;·&nbsp; h-index {stats.hIndex}
        <span class="asof"> — Google Scholar, {stats.asOf}</span>
      </p>
    )}
    <div class="list">
      {papers.map((paper) => (
        <PaperEntry paper={paper} scholar={scholarMap.get(paper.id)} />
      ))}
    </div>
  </section>

  <section class="contact">
    <div class="hd">
      <h2>Contact</h2>
    </div>
    <p class="body">
      I'm happy to hear from anyone working on correlated noise, exact results,
      or the statistical physics of learning. Email is fastest.
    </p>
    <div class="addr">
      <a href="mailto:marco.biroli@gmail.com">marco.biroli@gmail.com</a><br />
      <a href="https://scholar.google.com/citations?user=U4DVTL0AAAAJ">Google Scholar</a>
      &nbsp;·&nbsp;
      <a href="https://github.com/marcobiroli">GitHub</a>
    </div>
  </section>
</BaseLayout>
