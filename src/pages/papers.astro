---
import BaseLayout from '../layouts/BaseLayout.astro';
import PaperEntry from '../components/PaperEntry.astro';
import { getCollection } from 'astro:content';

const papers = (await getCollection('papers')).sort(
  (a, b) => b.data.year - a.data.year,
);
---
<BaseLayout title="Papers — Marco Biroli">
  <section class="pubs no-rule" style="padding-top: 50px;">
    <div class="hd">
      <div class="label">— Publications</div>
      <h2>Every <em>paper</em>, reverse chronological.</h2>
    </div>
    <p style="color: var(--muted); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; margin: 0 0 28px;">
      <a href="https://scholar.google.com/citations?user=U4DVTL0AAAAJ">Google Scholar</a>
      &nbsp;·&nbsp; <a href="/papers.bib">BibTeX</a>
      &nbsp;·&nbsp; <a href="/llms.txt">llms.txt</a>
    </p>
    <div class="list">
      {papers.map((paper) => <PaperEntry paper={paper} showSummary />)}
    </div>
  </section>
</BaseLayout>
