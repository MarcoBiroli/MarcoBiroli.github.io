---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import 'katex/dist/katex.min.css';

interface Props {
  title: string;
  description?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  ogType?: 'website' | 'article' | 'profile';
  publishedTime?: string;
  mdAlternate?: string;
  keywords?: string[];
}
const {
  title,
  description = 'Marco Biroli — postdoctoral Research Scholar at the University of Chicago (2025–). Statistical physics of extreme values, correlated particle systems, and machine learning. PhD from LPTMS, Université Paris-Saclay (2025).',
  jsonLd,
  ogType = 'website',
  publishedTime,
  mdAlternate,
  keywords,
} = Astro.props;

const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.pathname;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Marco Biroli" />
    {keywords && <meta name="keywords" content={keywords.join(', ')} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="color-scheme" content="light dark" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Marco Biroli" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {publishedTime && <meta property="article:author" content="Marco Biroli" />}
    <link rel="alternate" type="application/rss+xml" title="Marco Biroli — notes" href="/rss.xml" />
    {mdAlternate && <link rel="alternate" type="text/markdown" href={mdAlternate} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400;1,9..144,500&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored ?? (prefersDark ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
  </head>
  <body>
    <div class="page">
      <Header />
      <slot />
      <Footer />
    </div>
  </body>
</html>
