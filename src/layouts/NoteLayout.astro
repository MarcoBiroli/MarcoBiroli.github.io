---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  summary: string;
  slug: string;
  tags?: string[];
}
const { title, date, summary, slug, tags } = Astro.props;
const iso = date.toISOString();
const isoDate = iso.slice(0, 10);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: summary,
  datePublished: iso,
  author: {
    '@type': 'Person',
    name: 'Marco Biroli',
    url: 'https://marcobiroli.github.io',
  },
  keywords: tags ?? [],
  mainEntityOfPage: `https://marcobiroli.github.io/notes/${slug}`,
};
---
<BaseLayout
  title={`${title} — Marco Biroli`}
  description={summary}
  jsonLd={jsonLd}
  ogType="article"
  publishedTime={iso}
  mdAlternate={`/notes/${slug}.md`}
  keywords={tags}
>
  <article class="article">
    <div class="kicker">
      <time datetime={isoDate}>{isoDate}</time>
    </div>
    <h1>{title}</h1>
    <p class="dek">{summary}</p>
    <hr />
    <slot />
    <div class="post-nav">
      <a href="/notes">← all notes</a>
      &nbsp;·&nbsp;
      <a href={`/notes/${slug}.md`}>view as markdown</a>
    </div>
  </article>
</BaseLayout>
