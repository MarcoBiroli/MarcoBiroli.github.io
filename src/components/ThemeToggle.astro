<button id="theme-toggle" type="button" aria-label="Toggle color scheme" class="theme-toggle">
  <span aria-hidden="true">◐</span>
</button>
<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const curr = document.documentElement.dataset.theme;
    const next = curr === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    try { localStorage.setItem('theme', next); } catch {}
    document.dispatchEvent(new CustomEvent('theme-change', { detail: { theme: next } }));
  });
</script>
