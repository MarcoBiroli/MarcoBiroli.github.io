---
import { getCollection, render } from 'astro:content';

const news = (await getCollection('news')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const latest = news.slice(0, 6);
const rendered = await Promise.all(
  latest.map(async (item) => ({ item, Content: (await render(item)).Content })),
);
---
<section id="news">
  <div class="hd">
    <h2>News</h2>
  </div>
  <div class="note-list">
    {rendered.map(({ item, Content }) => (
      <article>
        <div class="date">{item.data.date.toISOString().slice(0, 10)}</div>
        <div>
          <h3>
            {item.data.link ? (
              <a href={item.data.link}>{item.data.title}</a>
            ) : (
              item.data.title
            )}
          </h3>
          <Content />
        </div>
      </article>
    ))}
  </div>
</section>
