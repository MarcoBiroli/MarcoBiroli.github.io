---
---
<div class="plate">
  <div class="frame">
    <span class="fig-tag">Fig. 1 — resetting brownian gas</span>
    <canvas id="fig-gas"></canvas>
  </div>
  <div class="cap">
    <span class="n">FIG. 1</span>
    <span>
      <em>N</em> non-interacting diffusers on the real line, reset together at
      Poisson times (vertical marks). The reset events alone — no direct
      interaction — couple them; the apparent independence is, by construction,
      false. <a href="https://arxiv.org/abs/2211.00563">Biroli, Larralde,
      Majumdar &amp; Schehr, <em>PRL</em> 130, 207101 (2023)</a>.
    </span>
  </div>
</div>

<script>
  function mulberry32(seed: number) {
    let s = seed >>> 0;
    return () => {
      s = (s + 0x6d2b79f5) >>> 0;
      let t = Math.imul(s ^ (s >>> 15), 1 | s);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }
  function randn(rng: () => number) {
    const u = Math.max(rng(), 1e-9);
    const v = rng();
    return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
  }
  function setupCanvas(canvas: HTMLCanvasElement) {
    const rect = canvas.getBoundingClientRect();
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = Math.max(2, Math.floor(rect.width * dpr));
    canvas.height = Math.max(2, Math.floor(rect.height * dpr));
    const ctx = canvas.getContext('2d')!;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    return { ctx, W: rect.width, H: rect.height };
  }

  type Handle = { destroy: () => void };
  let handle: Handle | null = null;

  function startGas(): Handle {
    const canvas = document.getElementById('fig-gas') as HTMLCanvasElement | null;
    if (!canvas) return { destroy() {} };

    const N = 40;
    const sigma = 1.0;
    const resetRate = 0.008;
    const maxLen = 900;
    const seed = 11;
    const lineWidth = 0.9;

    const cs = getComputedStyle(document.documentElement);
    const color = cs.getPropertyValue('--figure-trace').trim() || '#1d4ed8';
    const resetColor = cs.getPropertyValue('--figure-reset').trim() || '#6a6f78';
    const traceAlpha = document.documentElement.dataset.theme === 'dark' ? 0.42 : 0.55;

    let { ctx, W, H } = setupCanvas(canvas);
    let running = true;
    let t = 0;
    const history: Array<Array<{ t: number; y: number; reset: boolean }>> = Array.from(
      { length: N },
      () => []
    );
    const rng = mulberry32(seed);

    function step() {
      const resetNow = rng() < resetRate;
      t++;
      for (let i = 0; i < N; i++) {
        const prev = history[i].length ? history[i][history[i].length - 1].y : 0;
        const y = resetNow ? 0 : prev + sigma * randn(rng);
        history[i].push({ t, y, reset: resetNow });
      }
      if (history[0].length > maxLen) for (let i = 0; i < N; i++) history[i].shift();
    }

    function render() {
      ctx.clearRect(0, 0, W, H);

      let maxAbs = 1;
      for (let i = 0; i < N; i++) {
        for (let j = 0; j < history[i].length; j++) {
          const a = Math.abs(history[i][j].y);
          if (a > maxAbs) maxAbs = a;
        }
      }
      const ys = (H / 2 - 10) / maxAbs;
      const t0 = history[0].length ? history[0][0].t : 0;
      const t1 = t;
      const span = Math.max(1, t1 - t0);
      const xs = (tt: number) => ((tt - t0) / span) * W;

      ctx.strokeStyle = resetColor;
      ctx.globalAlpha = 0.15;
      ctx.lineWidth = 1;
      ctx.setLineDash([2, 3]);
      if (history[0].length) {
        for (let j = 1; j < history[0].length; j++) {
          if (history[0][j].reset) {
            const x = xs(history[0][j].t);
            ctx.beginPath();
            ctx.moveTo(x, 0);
            ctx.lineTo(x, H);
            ctx.stroke();
          }
        }
      }
      ctx.setLineDash([]);
      ctx.globalAlpha = 1;

      ctx.strokeStyle = color;
      ctx.globalAlpha = traceAlpha;
      ctx.lineWidth = lineWidth;
      for (let i = 0; i < N; i++) {
        ctx.beginPath();
        const p = history[i];
        for (let j = 0; j < p.length; j++) {
          const x = xs(p[j].t);
          const y = H / 2 - p[j].y * ys;
          if (j === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.stroke();
      }
      ctx.globalAlpha = 1;
    }

    function loop() {
      if (!running) return;
      step();
      render();
      requestAnimationFrame(loop);
    }
    loop();

    const onResize = () => {
      const s = setupCanvas(canvas);
      ctx = s.ctx;
      W = s.W;
      H = s.H;
    };
    window.addEventListener('resize', onResize);

    return {
      destroy() {
        running = false;
        window.removeEventListener('resize', onResize);
      },
    };
  }

  function restart() {
    if (handle) handle.destroy();
    handle = startGas();
  }

  restart();
  document.addEventListener('theme-change', restart);
  const mo = new MutationObserver(restart);
  mo.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
</script>
