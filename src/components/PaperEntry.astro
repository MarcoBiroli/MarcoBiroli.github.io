---
interface Props {
  paper: {
    data: {
      title: string;
      authors: string[];
      venue: string;
      year: number;
      arxiv?: string;
      pdf?: string;
      code?: string;
      doi?: string;
      citations?: number;
      highlighted?: boolean;
      summary?: string;
    };
  };
  showSummary?: boolean;
}
const { paper, showSummary = false } = Astro.props;
const p = paper.data;
const authorsHtml = p.authors
  .map((a) => (a.toLowerCase().includes('biroli') ? `<b>${a}</b>` : a))
  .join(', ');
---
<article class={`pub ${p.highlighted ? 'hl' : ''}`}>
  <div class="yr">{p.year}</div>
  <div>
    <div class="t">{p.title}</div>
    <div class="au" set:html={authorsHtml} />
    <div class="vn">{p.venue}</div>
    {showSummary && p.summary && <div class="summary">{p.summary}</div>}
  </div>
  <div class="lk">
    {p.arxiv && <a href={p.arxiv}>arXiv</a>}
    {p.doi && <a href={p.doi}>DOI</a>}
    {p.pdf && <a href={p.pdf}>PDF</a>}
    {p.code && <a href={p.code}>code</a>}
  </div>
</article>
