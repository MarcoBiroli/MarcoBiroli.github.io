---
---
<aside class="side-art side-art-left" aria-hidden="true">
  <canvas id="side-art-canvas-left" class="side-art-canvas"></canvas>
</aside>
<aside class="side-art side-art-right" aria-hidden="true">
  <canvas id="side-art-canvas-right" class="side-art-canvas"></canvas>
</aside>

<style>
  .side-art {
    position: fixed;
    top: 0;
    bottom: 0;
    width: calc((100vw - var(--max-width) - 3rem) / 2);
    max-width: 360px;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .side-art-left { left: 0; }
  .side-art-right { right: 0; }
  .side-art-canvas {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.85;
  }
  :root[data-theme='dark'] .side-art-canvas { opacity: 0.6; }

  @media (max-width: 1280px) {
    .side-art { display: none; }
  }
</style>

<script>
  type RGB = [number, number, number];

  const palettes: Record<'light' | 'dark', RGB[]> = {
    light: [
      [11, 92, 171],
      [224, 122, 53],
      [193, 75, 90],
      [42, 138, 138],
      [217, 181, 96],
      [64, 74, 88],
    ],
    dark: [
      [110, 168, 254],
      [255, 167, 106],
      [240, 124, 142],
      [92, 192, 192],
      [240, 208, 132],
      [200, 210, 225],
    ],
  };

  function mulberry32(seed: number) {
    let s = seed >>> 0;
    return function () {
      s = (s + 0x6d2b79f5) >>> 0;
      let t = Math.imul(s ^ (s >>> 15), 1 | s);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }

  function makeValueNoise(rng: () => number) {
    const size = 64;
    const grid = new Float32Array(size * size);
    for (let i = 0; i < grid.length; i++) grid[i] = rng();
    const fade = (t: number) => t * t * t * (t * (t * 6 - 15) + 10);
    return (x: number, y: number) => {
      const xi = ((Math.floor(x) % size) + size) % size;
      const yi = ((Math.floor(y) % size) + size) % size;
      const xf = x - Math.floor(x);
      const yf = y - Math.floor(y);
      const u = fade(xf), v = fade(yf);
      const xi1 = (xi + 1) % size;
      const yi1 = (yi + 1) % size;
      const v00 = grid[yi * size + xi];
      const v10 = grid[yi * size + xi1];
      const v01 = grid[yi1 * size + xi];
      const v11 = grid[yi1 * size + xi1];
      const a = v00 + u * (v10 - v00);
      const b = v01 + u * (v11 - v01);
      return a + v * (b - a);
    };
  }

  function drawSideArt(canvas: HTMLCanvasElement, seed: number, side: 'left' | 'right') {
    const rect = canvas.getBoundingClientRect();
    if (rect.width < 2 || rect.height < 2) return;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = Math.floor(rect.width * dpr);
    canvas.height = Math.floor(rect.height * dpr);
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    const W = rect.width, H = rect.height;
    ctx.clearRect(0, 0, W, H);

    const theme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
    const palette = palettes[theme];

    const rng = mulberry32(seed);
    const noise = makeValueNoise(mulberry32(seed ^ 0x9e3779b1));

    const noiseScale = 0.0055 + rng() * 0.004;
    const angleMul = 2.2 + rng() * 1.8;
    const stepLen = 1.5;
    const maxSteps = 420;
    const numParticles = Math.max(80, Math.floor((W * H) / 420));

    for (let n = 0; n < numParticles; n++) {
      let x = rng() * W;
      let y = rng() * H;
      const col = palette[Math.floor(rng() * palette.length)];
      const width = 0.5 + rng() * rng() * 3.2;
      const alpha = 0.05 + rng() * 0.13;
      const steps = Math.floor(140 + rng() * maxSteps);
      const dir = rng() < 0.5 ? 1 : -1;

      ctx.strokeStyle = `rgba(${col[0]},${col[1]},${col[2]},${alpha})`;
      ctx.lineWidth = width;
      ctx.lineCap = 'round';
      ctx.beginPath();
      ctx.moveTo(x, y);

      for (let s = 0; s < steps; s++) {
        const a = noise(x * noiseScale, y * noiseScale) * Math.PI * angleMul;
        x += Math.cos(a) * stepLen * dir;
        y += Math.sin(a) * stepLen * dir;
        if (x < -8 || y < -8 || x > W + 8 || y > H + 8) break;
        ctx.lineTo(x, y);
      }
      ctx.stroke();
    }

    const dots = 18 + Math.floor(rng() * 28);
    for (let i = 0; i < dots; i++) {
      const col = palette[Math.floor(rng() * palette.length)];
      const dx = side === 'left' ? W - rng() * 44 - 4 : rng() * 44 + 4;
      const dy = rng() * H;
      const r = 0.6 + rng() * 1.8;
      ctx.fillStyle = `rgba(${col[0]},${col[1]},${col[2]},${0.3 + rng() * 0.35})`;
      ctx.beginPath();
      ctx.arc(dx, dy, r, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  let currentSeed = Math.floor(Math.random() * 0xffffff);

  function renderAll() {
    const left = document.getElementById('side-art-canvas-left') as HTMLCanvasElement | null;
    const right = document.getElementById('side-art-canvas-right') as HTMLCanvasElement | null;
    if (left) drawSideArt(left, currentSeed, 'left');
    if (right) drawSideArt(right, (currentSeed ^ 0xdeadbeef) >>> 0, 'right');
  }

  renderAll();

  let resizeTimer = 0 as unknown as ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(renderAll, 150);
  });

  const mo = new MutationObserver(() => renderAll());
  mo.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });
</script>
